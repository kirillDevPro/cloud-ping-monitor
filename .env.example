# === СЕКРЕТНЫЕ ПАРАМЕТРЫ ===
# Несекретные настройки находятся в src/config/config.yaml

# Telegram Bot Token
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# === АДМИНИСТРАТОРЫ ===
# Telegram User IDs администраторов бота (через запятую)
# Узнать свой ID можно у @userinfobot в Telegram
ADMIN_IDS=123456789

# ============================================================================
# ПРОВАЙДЕРЫ (Auto-Discovery)
# ============================================================================
# Провайдеры автоматически обнаруживаются по паттернам переменных!
# Конфигурация в config.yaml НЕ требуется.
#
# Паттерны:
#   HETZNER_{SUFFIX}_API_KEY       -> alias=hetzner_{suffix}
#   VULTR_{SUFFIX}_API_KEY         -> alias=vultr_{suffix}
#   AWS_{SUFFIX}_ACCESS_KEY_ID +
#   AWS_{SUFFIX}_SECRET_ACCESS_KEY -> alias=aws_{suffix}
#
# Автоматически генерируется:
#   - display_name: "Hetzner (suffix)", "Vultr", "AWS (suffix)"
#     (если suffix="main", то просто "Hetzner", "Vultr", "AWS")
#   - emoji: [H] для Hetzner, [V] для Vultr, [A] для AWS
#   - AWS: regions=null (все регионы), enable_ec2=true, enable_lightsail=true

# --- Hetzner Cloud ---
# Получите в Hetzner Cloud Console: https://console.hetzner.cloud/
# Примеры:
#   HETZNER_PROD_API_KEY -> alias=hetzner_prod, display="Hetzner (prod)"
#   HETZNER_STAGING_API_KEY    -> alias=hetzner_staging, display="Hetzner (staging)"
#   HETZNER_MAIN_API_KEY   -> alias=hetzner_main, display="Hetzner"
HETZNER_PROD_API_KEY=
HETZNER_STAGING_API_KEY=

# --- Vultr ---
# Получите в настройках аккаунта Vultr: https://my.vultr.com/settings/#settingsapi
# Примеры:
#   VULTR_MAIN_API_KEY -> alias=vultr_main, display="Vultr"
#   VULTR_PROD_API_KEY -> alias=vultr_prod, display="Vultr (prod)"
VULTR_MAIN_API_KEY=

# --- AWS ---
# Создайте IAM пользователя с правами: EC2, Lightsail, Cost Explorer (опционально)
# https://console.aws.amazon.com/iam/
# ВАЖНО: Нужны ОБА ключа для обнаружения провайдера!
# Примеры:
#   AWS_MAIN_ACCESS_KEY_ID + AWS_MAIN_SECRET_ACCESS_KEY -> alias=aws_main, display="AWS"
#   AWS_PROD_ACCESS_KEY_ID + AWS_PROD_SECRET_ACCESS_KEY -> alias=aws_prod, display="AWS (prod)"
AWS_MAIN_ACCESS_KEY_ID=
AWS_MAIN_SECRET_ACCESS_KEY=
